#!/usr/bin/env bash
# Thin wrapper so you can run `./keel <command>` without activating the venv.
# Resolves the repo root via the script's own location so it works from any cwd.
set -e
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
HERE="$(cd "$(dirname "$SELF")" && pwd)"
if [ ! -x "$HERE/.venv/bin/python" ]; then
    echo "keel: .venv missing — run 'bash setup.sh' first" >&2
    exit 1
fi
exec "$HERE/.venv/bin/python" "$HERE/run.py" "$@"
